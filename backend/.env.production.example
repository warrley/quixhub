# On the VPS: cp .env.production.example .env.production, then fill in the
# blanks below. Read by docker-compose.prod.yml via `env_file`. Never commit
# the filled-in file.

PORT=4000
NODE_ENV=production

# Postgres — hostname is the docker-compose service name (internal network),
# not localhost, and port is the container's own 5432.
DATABASE_URL=postgres://quixhub:<POSTGRES_PASSWORD>@postgres:5432/quixhub
POSTGRES_USER=quixhub
POSTGRES_PASSWORD=
POSTGRES_DB=quixhub

# Auth — generate fresh secrets, do not reuse dev values:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Material uploads — mounted as a named Docker volume at /app/uploads.
UPLOAD_DIR=./uploads

# Seed admin account (used by `npm run seed:admin`)
SEED_ADMIN_NAME=Admin QuixHub
SEED_ADMIN_EMAIL=admin@ufc.br
SEED_ADMIN_PASSWORD=

# Frontend origin for CORS — the Vercel deployment.
FRONTEND_ORIGIN=https://quixhub.warley.xyz

# Salt for hashing feedback voter identity — generate fresh for production.
FEEDBACK_SALT=
