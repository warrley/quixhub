# On the VPS: cp .env.production.example .env, then fill in the blanks
# below. Read both by the app itself (dotenv, default lookup) and by
# docker-compose.prod.yml (env_file, for the postgres container). Never
# commit the filled-in file.

PORT=4000
NODE_ENV=production

# Postgres — the container's port is published to 127.0.0.1 only, so the
# native (pm2) backend process connects via localhost.
DATABASE_URL=postgres://quixhub:<POSTGRES_PASSWORD>@localhost:5432/quixhub
POSTGRES_USER=quixhub
POSTGRES_PASSWORD=
POSTGRES_DB=quixhub

# Auth — generate fresh secrets, do not reuse dev values:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Material uploads — local disk on the VPS.
UPLOAD_DIR=./uploads

# Seed admin account (used by `npm run seed:admin`)
SEED_ADMIN_NAME=Admin QuixHub
SEED_ADMIN_EMAIL=admin@ufc.br
SEED_ADMIN_PASSWORD=

# Frontend origin for CORS — the Vercel deployment.
FRONTEND_ORIGIN=https://quixhub.warley.xyz

# Salt for hashing feedback voter identity — generate fresh for production.
FEEDBACK_SALT=
