# Copy to .env and adjust as needed. Matches the root docker-compose.yml services.

PORT=4000
NODE_ENV=development

# Postgres (docker-compose maps container 5432 -> host 55432)
DATABASE_URL=postgres://academy:academy@localhost:55432/academy

# Auth
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Material uploads — stored on local disk for now (no S3/MinIO dependency)
UPLOAD_DIR=./uploads

# Seed admin account (used by `npm run seed:admin`)
SEED_ADMIN_NAME=Admin QuixHub
SEED_ADMIN_EMAIL=admin@ufc.br
SEED_ADMIN_PASSWORD=change-me-admin

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:3000
