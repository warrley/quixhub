{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/docs-sync-reminder.sh",
            "statusMessage": "Checking docs sync..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/graphify-auto-update.sh",
            "statusMessage": "Updating graph..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/warley/.local/share/../bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/warley/.local/share/../bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}